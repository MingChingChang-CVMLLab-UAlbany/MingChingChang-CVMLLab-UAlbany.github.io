---
layout: default
---

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>

    <div class="pub-title-icons" style="font-size: 1.6rem;">
      <a href="https://scholar.google.com/citations?user=a3-Gl8YAAAAJ" target="_blank" rel="noopener noreferrer" title="Google Scholar" style="margin-right: 0.6rem;">
        <i class="ai ai-google-scholar"></i>
      </a>
      <a href="https://dblp.uni-trier.de/pid/21/4361.html" target="_blank" rel="noopener noreferrer" title="DBLP">
        <i class="ai ai-dblp"></i>
      </a>
    </div>

    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {{ content }}
  </article>
</div>