---
layout: default
---

<div class="post">
  <header class="post-header">
    <h1 class="post-title page-title-with-icons">
      <span>{{ page.title }}</span>

      <span class="page-title-icons">
        <a href="https://scholar.google.com/citations?user=a3-Gl8YAAAAJ" target="_blank" rel="noopener noreferrer" title="Google Scholar">
          <i class="ai ai-google-scholar"></i>
        </a>
        <a href="https://dblp.uni-trier.de/pid/21/4361.html" target="_blank" rel="noopener noreferrer" title="DBLP">
          <i class="ai ai-dblp"></i>
        </a>
      </span>
    </h1>

    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {{ content }}
  </article>
</div>