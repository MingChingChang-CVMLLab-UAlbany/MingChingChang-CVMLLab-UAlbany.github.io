---
layout: default
---

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="awards-cv">
      {% assign last_year = "" %}
      {% for item in site.data.awards %}
        {% if item.year != last_year %}
          <h2 class="award-year-heading">{{ item.year }}</h2>
          {% assign last_year = item.year %}
        {% endif %}

        <div class="award-entry">
          <div class="award-title">{{ item.title }}</div>

          {% if item.venue != "" %}
            <div class="award-venue">{{ item.venue }}</div>
          {% endif %}

          {% if item.detail != "" %}
            <div class="award-detail">{{ item.detail }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </article>
</div>