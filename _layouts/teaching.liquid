---
layout: default
---

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="teaching-cv">
      <section class="teaching-section">
        <h2 class="teaching-heading">UAlbany Courses</h2>
        <div class="teaching-list">
          {% for item in site.data.teaching.ualbany_courses %}
            <div class="teaching-entry">
              <div class="teaching-main">
                {% if item.role != "" %}
                  <span class="teaching-role">{{ item.role }}</span>,
                {% endif %}
                <span class="teaching-course">{{ item.course }}</span>
                {% if item.code != "" %}
                  <span class="teaching-code">{{ item.code }}</span>
                {% endif %}
                {% if item.institution != "" %}
                  <div class="teaching-inst">{{ item.institution }}</div>
                {% endif %}
                {% if item.note != "" %}
                  <div class="teaching-note">{{ item.note }}</div>
                {% endif %}
              </div>
              <div class="teaching-terms">{{ item.terms }}</div>
            </div>
          {% endfor %}
        </div>
      </section>

      <section class="teaching-section">
        <h2 class="teaching-heading">Guest / Visiting Courses</h2>
        <div class="teaching-list">
          {% for item in site.data.teaching.guest_visiting_courses %}
            <div class="teaching-entry">
              <div class="teaching-main">
                {% if item.role != "" %}
                  <span class="teaching-role">{{ item.role }}</span>,
                {% endif %}
                <span class="teaching-course">{{ item.course }}</span>
                {% if item.code != "" %}
                  <span class="teaching-code">{{ item.code }}</span>
                {% endif %}
                {% if item.institution != "" %}
                  <div class="teaching-inst">{{ item.institution }}</div>
                {% endif %}
                {% if item.note != "" %}
                  <div class="teaching-note">{{ item.note }}</div>
                {% endif %}
              </div>
              <div class="teaching-terms">{{ item.terms }}</div>
            </div>
          {% endfor %}
        </div>
      </section>
    </div>
  </article>
</div>

<style>
  .teaching-cv {
    margin-top: 1.25rem;
  }

  .teaching-section {
    margin-bottom: 2rem;
  }

  .teaching-heading {
    margin-bottom: 0.85rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--global-divider-color);
    font-size: 1.15rem;
    font-weight: 700;
  }

  .teaching-entry {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    padding: 0.45rem 0;
    align-items: start;
  }

  .teaching-main {
    line-height: 1.5;
  }

  .teaching-role {
    font-weight: 600;
  }

  .teaching-course {
    font-weight: 500;
  }

  .teaching-code {
    margin-left: 0.35rem;
    color: var(--global-text-color-light);
    font-weight: 500;
  }

  .teaching-inst,
  .teaching-note {
    color: var(--global-text-color-light);
    font-size: 0.96rem;
  }

  .teaching-terms {
    white-space: nowrap;
    font-weight: 600;
    color: var(--global-theme-color);
    margin-left: 1rem;
    text-align: right;
  }

  @media (max-width: 768px) {
    .teaching-entry {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }

    .teaching-terms {
      margin-left: 0;
      text-align: left;
      white-space: normal;
    }
  }
</style>